---
import ProductCard from '@components/ProductCard.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { business } from '@data/business';
import { categories } from '@data/categories';
import { products } from '@data/products';

const brands = [...new Set(products.map((product) => product.brand))].sort();
---

<BaseLayout
  title="Product Catalog | Smoke Valley Smoke Shop"
  description="Browse the Smoke Valley Smoke Shop static catalog for vapes, disposables, hookah, glass, accessories, CBD/Hemp, kratom, snacks, drinks, and more in Richmond, TX."
  path="/catalog/"
>
  <section class="section-pad bg-white">
    <div class="container-padded">
      <div class="section-heading">
        <h1 class="text-5xl md:text-6xl">Product catalog</h1>
        <p>
          Browse sample catalog categories and product cards. Prices, inventory, checkout, and online ordering are intentionally not enabled for Phase 1.
        </p>
      </div>

      <form class="mt-8 grid gap-4 rounded-2xl border border-smoke-200 bg-smoke-50 p-4 md:grid-cols-[1fr_0.7fr_0.7fr_auto]" id="catalog-filters" role="search">
        <label class="grid gap-2">
          <span class="text-sm font-black text-charcoal-900">Search</span>
          <input
            class="min-h-12 rounded-xl border border-smoke-200 bg-white px-4 text-base"
            id="catalog-search"
            type="search"
            placeholder="Search product, brand, category, or tag"
          />
        </label>
        <label class="grid gap-2">
          <span class="text-sm font-black text-charcoal-900">Category</span>
          <select class="min-h-12 rounded-xl border border-smoke-200 bg-white px-4 text-base" id="category-filter">
            <option value="">All categories</option>
            {categories.map((category) => <option value={category.name}>{category.name}</option>)}
          </select>
        </label>
        <label class="grid gap-2">
          <span class="text-sm font-black text-charcoal-900">Brand</span>
          <select class="min-h-12 rounded-xl border border-smoke-200 bg-white px-4 text-base" id="brand-filter">
            <option value="">All brands</option>
            {brands.map((brand) => <option value={brand}>{brand}</option>)}
          </select>
        </label>
        <div class="flex items-end">
          <button class="button-secondary w-full" id="clear-filters" type="button">Clear filters</button>
        </div>
      </form>

      <div class="mt-5 flex flex-col gap-3 text-sm font-bold text-smoke-500 sm:flex-row sm:items-center sm:justify-between">
        <p id="catalog-results-count" aria-live="polite">{products.length} sample products shown</p>
        <p>Selection may vary. Call store for current availability.</p>
      </div>

      <div class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3" id="product-grid">
        {products.map((product) => <ProductCard product={product} />)}
      </div>

      <div class="empty-state mt-8 rounded-2xl border border-smoke-200 bg-smoke-50 p-8 text-center" id="catalog-empty" hidden>
        <h2 class="text-2xl font-black text-charcoal-900">No matching products</h2>
        <p class="mt-2 text-sm font-bold text-smoke-500">Try clearing filters, or call Smoke Valley to ask about what you need.</p>
        <a class="button-primary mt-5" href={business.phoneHref}>Call Store</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const searchInput = document.getElementById('catalog-search') as HTMLInputElement | null;
  const categoryFilter = document.getElementById('category-filter') as HTMLSelectElement | null;
  const brandFilter = document.getElementById('brand-filter') as HTMLSelectElement | null;
  const clearButton = document.getElementById('clear-filters') as HTMLButtonElement | null;
  const cards = Array.from(document.querySelectorAll<HTMLElement>('[data-product-card]'));
  const count = document.getElementById('catalog-results-count');
  const empty = document.getElementById('catalog-empty');

  const applyFilters = () => {
    const query = searchInput?.value.trim().toLowerCase() ?? '';
    const category = categoryFilter?.value ?? '';
    const brand = brandFilter?.value ?? '';
    let visible = 0;

    cards.forEach((card) => {
      const matchesSearch = !query || (card.dataset.search ?? '').includes(query);
      const matchesCategory = !category || card.dataset.category === category;
      const matchesBrand = !brand || card.dataset.brand === brand;
      const shouldShow = matchesSearch && matchesCategory && matchesBrand;

      card.hidden = !shouldShow;
      if (shouldShow) visible += 1;
    });

    if (count) count.textContent = `${visible} sample product${visible === 1 ? '' : 's'} shown`;
    if (empty) empty.hidden = visible !== 0;
  };

  const params = new URLSearchParams(window.location.search);
  const categoryFromUrl = params.get('category');
  if (categoryFromUrl && categoryFilter) {
    categoryFilter.value = categoryFromUrl;
  }

  searchInput?.addEventListener('input', applyFilters);
  categoryFilter?.addEventListener('change', applyFilters);
  brandFilter?.addEventListener('change', applyFilters);
  clearButton?.addEventListener('click', () => {
    if (searchInput) searchInput.value = '';
    if (categoryFilter) categoryFilter.value = '';
    if (brandFilter) brandFilter.value = '';
    applyFilters();
  });

  applyFilters();
</script>
