---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found | Smoke Valley Smoke Shop"
  description="The requested Smoke Valley Smoke Shop page could not be found."
  path="/404/"
>
  <section class="section-pad bg-white">
    <div class="container-padded max-w-3xl text-center">
      <p class="text-sm font-black uppercase tracking-[0.16em] text-valley-700">404</p>
      <h1 class="mt-3 text-5xl font-black leading-tight text-charcoal-900 md:text-6xl">Page not found</h1>
      <p class="mt-4 text-lg leading-8 text-smoke-500">The page you requested is not available. Head back home or browse products.</p>
      <div class="mt-7 flex flex-col justify-center gap-3 sm:flex-row">
        <a class="button-primary" href="/">Home</a>
        <a class="button-secondary" href="/products/">Products</a>
      </div>
    </div>
  </section>
</BaseLayout>
