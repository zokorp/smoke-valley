---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Disclaimers | Smoke Valley Smoke Shop"
  description="Read simple website, age-restriction, product-selection, CBD/Hemp, and kratom disclaimers for Smoke Valley Smoke Shop in Richmond, TX."
  path="/disclaimers/"
>
  <section class="section-pad bg-white">
    <div class="container-padded max-w-4xl">
      <div class="section-heading">
        <h1 class="text-5xl md:text-6xl">Disclaimers</h1>
        <p>Simple legal and product notices for the Smoke Valley website.</p>
      </div>
      <div class="mt-8 grid gap-5">
        <section class="card p-6">
          <h2 class="text-2xl font-black text-charcoal-900">Adults 21+ only</h2>
          <p class="mt-3 leading-7 text-smoke-500">
            This website is intended for adults 21 years of age or older. Products are age-restricted, and a valid government-issued ID may be required in store.
          </p>
        </section>
        <section class="card p-6">
          <h2 class="text-2xl font-black text-charcoal-900">Product selection</h2>
          <p class="mt-3 leading-7 text-smoke-500">
            Product selection may vary. Website information may change without notice. No online sales, checkout, shipping, or account creation are currently available.
          </p>
        </section>
        <section class="card p-6">
          <h2 class="text-2xl font-black text-charcoal-900">CBD/Hemp and kratom</h2>
          <p class="mt-3 leading-7 text-smoke-500">
            CBD/Hemp and kratom products are not intended to diagnose, treat, cure, or prevent any disease. Consult a qualified professional before using CBD/Hemp or kratom products, especially if pregnant, nursing, taking medication, or managing a medical condition.
          </p>
        </section>
        <section class="card p-6">
          <h2 class="text-2xl font-black text-charcoal-900">Safe storage and laws</h2>
          <p class="mt-3 leading-7 text-smoke-500">
            Keep products away from children and pets. Follow all applicable federal, state, and local laws.
          </p>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>
