---
import BaseLayout from '@layouts/BaseLayout.astro';
import { business } from '@data/business';
import { categories } from '@data/categories';
---

<BaseLayout
  title="About Smoke Valley Smoke Shop"
  description="Learn about Smoke Valley Smoke Shop, a local Richmond, TX smoke shop for vapes, hookah, glass, accessories, CBD/Hemp, kratom, and more for adults 21+."
  path="/about/"
>
  <section class="section-pad bg-white">
    <div class="container-padded grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <div class="section-heading">
        <h1 class="text-5xl md:text-6xl">Local, friendly, easy to visit.</h1>
        <p>
          Smoke Valley serves Richmond, Texas with a clean, convenient retail experience for adults 21+.
        </p>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <a class="button-primary" href={business.directionsUrl} target="_blank" rel="noreferrer">Get Directions</a>
          <a class="button-secondary" href={business.phoneHref}>Call Store</a>
        </div>
      </div>
      <div class="media-frame aspect-[4/3] shadow-[var(--shadow-soft)]">
        <img class="h-full w-full object-cover" src="/images/store/interior-brand.svg" alt="Smoke Valley interior brand graphic" />
      </div>
    </div>
  </section>

  <section class="section-pad retail-band">
    <div class="container-padded">
      <div class="section-heading">
        <h2 class="text-4xl md:text-5xl">What you can ask about</h2>
        <p>
          Browse product categories online, then call, message, or visit to ask about current selection. CBD/Hemp and kratom information on this site avoids medical claims.
        </p>
      </div>
      <div class="mt-8 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {
          categories.map((category) => (
            <div class="rounded-2xl border border-smoke-200 bg-white p-5">
              <h3 class="text-lg font-black text-charcoal-900">{category.name}</h3>
              <p class="mt-2 text-sm leading-6 text-smoke-500">{category.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
