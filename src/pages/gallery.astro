---
import BaseLayout from '@layouts/BaseLayout.astro';
import { business } from '@data/business';
---

<BaseLayout
  title="Gallery | Smoke Valley Smoke Shop"
  description="Smoke Valley Smoke Shop photos will be added after real store images are available."
  path="/gallery/"
  noindex={true}
>
  <section class="section-pad bg-white">
    <div class="container-padded">
      <div class="section-heading">
        <h1 class="text-5xl md:text-6xl">Gallery coming soon</h1>
        <p>Real Smoke Valley storefront and shop photos will be added here after they are ready for public launch.</p>
      </div>
      <div class="mt-8 rounded-2xl border border-smoke-200 bg-smoke-50 p-6">
        <h2 class="text-2xl font-black text-charcoal-900">Visit Smoke Valley</h2>
        <p class="mt-2 leading-7 text-smoke-500">{business.formattedAddress}</p>
        <div class="mt-5 flex flex-col gap-3 sm:flex-row">
          <a class="button-primary" href={business.directionsUrl} target="_blank" rel="noreferrer">Get Directions</a>
          <a class="button-secondary" href={business.phoneHref}>Call Store</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
