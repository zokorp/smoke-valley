---
import { Gift, MapPin, Phone } from '@lucide/astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { business } from '@data/business';
import { rewards } from '@data/rewards';
---

<BaseLayout
  title="Rewards | Smoke Valley Smoke Shop"
  description="Learn about the Smoke Valley rewards program in Richmond, TX. Sign up by phone number for rewards and updates when available."
  path="/rewards/"
>
  <section class="section-pad bg-white">
    <div class="container-padded grid gap-10 lg:grid-cols-[1fr_0.9fr] lg:items-center">
      <div class="section-heading">
        <h1 class="text-5xl md:text-6xl">Rewards</h1>
        <p>
          Sign up using your phone number to gain access to rewards when purchasing in-store. You can also ask the Smoke Valley team about rewards at checkout.
        </p>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <a class="button-primary" href={rewards.signupHref} target="_blank" rel="noreferrer">
            <Gift size={18} aria-hidden="true" />
            Join Rewards
          </a>
        </div>
      </div>
      <div class="media-frame aspect-[4/3] shadow-[var(--shadow-soft)]">
        <img class="h-full w-full object-cover" src="/images/store/rewards-brand.svg" alt="Smoke Valley rewards brand graphic" />
      </div>
    </div>
  </section>

  <section class="section-pad retail-band">
    <div class="container-padded grid gap-5 md:grid-cols-3">
      <div class="card p-6">
        <h2 class="text-2xl font-black text-charcoal-900">1. Join rewards</h2>
        <p class="mt-3 leading-7 text-smoke-500">Use the rewards signup button or ask staff to help connect your phone number in store.</p>
      </div>
      <div class="card p-6">
        <h2 class="text-2xl font-black text-charcoal-900">2. Shop in store</h2>
        <p class="mt-3 leading-7 text-smoke-500">Rewards are connected to in-store purchases and promotions when available.</p>
      </div>
      <div class="card p-6">
        <h2 class="text-2xl font-black text-charcoal-900">3. Watch for updates</h2>
        <p class="mt-3 leading-7 text-smoke-500">Follow updates from Smoke Valley and ask staff about current rewards or promotions.</p>
      </div>
    </div>
    <div class="container-padded mt-8 flex flex-col gap-3 sm:flex-row">
      <a class="button-primary" href={business.directionsUrl} target="_blank" rel="noreferrer">
        <MapPin size={18} aria-hidden="true" />
        Visit us in store
      </a>
      <a class="button-secondary" href={business.phoneHref}>
        <Phone size={18} aria-hidden="true" />
        Call Store
      </a>
    </div>
  </section>
</BaseLayout>
