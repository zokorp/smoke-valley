---
import CategoryCard from '@components/CategoryCard.astro';
import BrandTiles from '@components/BrandTiles.astro';
import Hero from '@components/Hero.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { business } from '@data/business';
import { categories } from '@data/categories';
---

<BaseLayout
  title="Smoke Valley Smoke Shop | Richmond, TX"
  description="Smoke Valley Smoke Shop in Richmond, TX offers vapes, disposables, hookah, glass, accessories, CBD/Hemp, kratom, snacks, drinks, and more for adults 21+."
>
  <Hero />

  <section class="section-pad retail-band">
    <div class="container-padded">
      <div class="section-heading">
        <h2 class="text-4xl md:text-5xl">Shop by category</h2>
        <p>Browse popular product areas. No prices or inventory are shown online, and selection may vary in store.</p>
      </div>
      <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {categories.map((category) => <CategoryCard category={category} />)}
      </div>
    </div>
  </section>

  <section class="section-pad bg-white">
    <div class="container-padded">
      <div class="section-heading">
        <h2 class="text-4xl md:text-5xl">Featured brands</h2>
        <p>Ask staff about current selections from popular brands. This website does not guarantee stock or availability.</p>
      </div>
      <div class="mt-8">
        <BrandTiles />
      </div>
    </div>
  </section>

  <section class="section-pad retail-band">
    <div class="container-padded">
      <div class="section-heading">
        <h2 class="text-4xl md:text-5xl">Had a good visit?</h2>
        <p>Leave Smoke Valley a Google review and help local customers find us.</p>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <a class="button-primary" href={business.reviewUrl} target="_blank" rel="noreferrer">Leave us a Google review</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
