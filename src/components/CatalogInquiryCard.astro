---
import { MessageCircle, Phone } from '@lucide/astro';
import { business } from '@data/business';
import type { CatalogInquiry } from '@data/catalogInquiries';

type Props = {
  inquiry: CatalogInquiry;
};

const { inquiry } = Astro.props;
const searchText = [inquiry.title, inquiry.type, inquiry.category, inquiry.brand, inquiry.subcategory, inquiry.description, ...inquiry.flavorExamples, ...inquiry.tags]
  .join(' ')
  .toLowerCase();
---

<article
  class="catalog-card card flex h-full flex-col overflow-hidden"
  data-catalog-card
  data-search={searchText}
  data-category={inquiry.category}
  data-brand={inquiry.brand}
>
  <div class="media-frame aspect-[4/3] rounded-none border-0 border-b border-smoke-200">
    <img class="h-full w-full object-cover" src={inquiry.displayImage} alt={`${inquiry.title} retail graphic`} loading="lazy" />
  </div>
  <div class="flex flex-1 flex-col p-3 sm:p-4">
    <div class="flex flex-wrap gap-1.5">
      <span class="rounded-full bg-valley-50 px-2 py-1 text-[0.68rem] font-black text-valley-700">{inquiry.type}</span>
      <span class="rounded-full bg-smoke-50 px-2 py-1 text-[0.68rem] font-black text-charcoal-700">{inquiry.brand}</span>
    </div>
    <h2 class="mt-3 text-base font-black leading-tight text-charcoal-900 sm:text-lg">{inquiry.title}</h2>
    <p class="mt-1 text-xs font-black uppercase tracking-[0.12em] text-valley-700">{inquiry.subcategory}</p>
    <p class="mt-2 text-sm leading-6 text-charcoal-700">{inquiry.description}</p>
    <div class="mt-3 flex flex-wrap gap-1.5">
      {inquiry.flavorExamples.map((example) => <span class="rounded-full border border-smoke-200 px-2 py-1 text-[0.68rem] font-bold text-smoke-500">{example}</span>)}
    </div>
    <p class="mt-3 text-xs font-bold leading-5 text-smoke-500">Selection may vary. Ask for current availability.</p>
    <div class="mt-auto grid grid-cols-1 gap-2 pt-4 min-[420px]:grid-cols-2">
      <a class="button-primary catalog-card__action" href={business.phoneHref}>
        <Phone size={16} aria-hidden="true" />
        Call
      </a>
      <a class="button-secondary catalog-card__action" href={business.whatsappHref} target="_blank" rel="noreferrer">
        <MessageCircle size={16} aria-hidden="true" />
        WhatsApp
      </a>
    </div>
  </div>
</article>
