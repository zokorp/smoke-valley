---
import { MapPinned } from '@lucide/astro';
import { business } from '@data/business';
---

<section class="card overflow-hidden">
  <iframe
    class="map-embed"
    title="Map to Smoke Valley in Richmond, Texas"
    src={business.mapEmbedUrl}
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
  ></iframe>
  <div class="flex flex-col gap-4 border-t border-smoke-200 p-5 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h2 class="text-lg font-black text-charcoal-900">Smoke Valley</h2>
      <p class="mt-1 text-sm font-bold text-smoke-500">{business.formattedAddress}</p>
    </div>
    <a class="button-primary" href={business.directionsUrl} target="_blank" rel="noreferrer">
      <MapPinned size={18} aria-hidden="true" />
      Get Directions
    </a>
  </div>
</section>
