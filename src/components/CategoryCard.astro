---
import type { Category } from '@data/categories';

type Props = {
  category: Category;
};

const { category } = Astro.props;
---

<a class="card group grid overflow-hidden text-left transition hover:-translate-y-1" href={`/catalog/?category=${encodeURIComponent(category.name)}`}>
  <div class="media-frame aspect-[4/3] rounded-none border-0 border-b border-smoke-200">
    <img class="h-full w-full object-cover transition group-hover:scale-[1.02]" src={category.image} alt={`${category.name} retail graphic`} loading="lazy" />
  </div>
  <div class="p-5">
    <h3 class="text-xl font-black text-charcoal-900">{category.name}</h3>
    <p class="mt-2 text-sm leading-6 text-smoke-500">{category.description}</p>
  </div>
</a>
