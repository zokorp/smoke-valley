---
import { MessageCircle, Phone } from '@lucide/astro';
import { business } from '@data/business';
import type { Product } from '@data/products';

type Props = {
  product: Product;
};

const { product } = Astro.props;
const searchText = [product.name, product.brand, product.category, product.subcategory, product.shortDescription, ...product.tags]
  .join(' ')
  .toLowerCase();
---

<article
  class="catalog-card card flex h-full flex-col overflow-hidden"
  data-product-card
  data-search={searchText}
  data-category={product.category}
  data-brand={product.brand}
>
  <div class="media-frame aspect-[4/3] rounded-none border-0 border-b border-smoke-200">
    <img class="h-full w-full object-cover" src={product.image} alt={`${product.name} placeholder image`} loading="lazy" />
  </div>
  <div class="flex flex-1 flex-col p-5">
    <div class="flex flex-wrap gap-2">
      <span class="rounded-full bg-valley-50 px-3 py-1 text-xs font-black text-valley-700">{product.category}</span>
      <span class="rounded-full bg-smoke-50 px-3 py-1 text-xs font-black text-charcoal-700">{product.brand}</span>
    </div>
    <h2 class="mt-4 text-xl font-black leading-tight text-charcoal-900">{product.name}</h2>
    <p class="mt-2 text-sm font-bold text-smoke-500">{product.shortDescription}</p>
    <p class="mt-3 text-sm leading-6 text-charcoal-700">{product.description}</p>
    <div class="mt-4 flex flex-wrap gap-2">
      {product.tags.map((tag) => <span class="rounded-full border border-smoke-200 px-2.5 py-1 text-xs font-bold text-smoke-500">#{tag}</span>)}
    </div>
    <p class="mt-4 text-sm font-bold text-smoke-500">Selection may vary. Call store for current availability.</p>
    <div class="mt-auto grid gap-2 pt-5">
      <a class="button-primary" href={business.phoneHref}>
        <Phone size={18} aria-hidden="true" />
        Call store to ask about this product
      </a>
      <a class="button-secondary" href={business.whatsappHref} target="_blank" rel="noreferrer">
        <MessageCircle size={18} aria-hidden="true" />
        WhatsApp store
      </a>
    </div>
  </div>
</article>
