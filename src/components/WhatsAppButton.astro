---
import { MessageCircle } from '@lucide/astro';
import { business } from '@data/business';
---

<a
  class="fixed bottom-5 right-5 z-30 inline-flex h-14 w-14 items-center justify-center rounded-full bg-valley-700 text-white shadow-2xl transition hover:-translate-y-0.5 hover:bg-valley-900 focus-visible:outline-white sm:h-auto sm:w-auto sm:px-5 sm:py-4"
  href={business.whatsappHref}
  target="_blank"
  rel="noreferrer"
  aria-label="Chat with Smoke Valley on WhatsApp"
>
  <MessageCircle size={24} aria-hidden="true" />
  <span class="ml-2 hidden text-sm font-black sm:inline">WhatsApp</span>
</a>
