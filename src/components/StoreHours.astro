---
import { business } from '@data/business';
---

<div class="rounded-2xl border border-smoke-200 bg-white p-5 shadow-sm">
  <h2 class="text-base font-black text-charcoal-900">Store Hours</h2>
  <dl class="mt-4 grid gap-3">
    {
      business.hours.map((hour) => (
        <div class="flex items-start justify-between gap-4 border-b border-smoke-100 pb-3 last:border-b-0 last:pb-0">
          <dt class="font-bold text-charcoal-700">{hour.label}</dt>
          <dd class="text-right font-extrabold text-charcoal-900">{hour.display}</dd>
        </div>
      ))
    }
  </dl>
</div>
