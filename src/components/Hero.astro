---
import { MapPin, Phone } from '@lucide/astro';
import MapEmbed from '@components/MapEmbed.astro';
import { business } from '@data/business';
---

<section class="home-hero">
  <div class="home-hero__background" aria-hidden="true">
    <img src="/images/store/product-wall-brand.svg" alt="" loading="eager" />
  </div>

  <div class="container-padded relative z-10 py-8 md:py-12">
    <div class="home-hero__content">
      <div class="grid gap-2">
        <h1 class="text-3xl font-black tracking-[0.08em] text-charcoal-900 uppercase md:text-4xl">Smoke Valley</h1>
        <a class="inline-flex items-start gap-2 text-sm font-bold leading-6 text-charcoal-700" href={business.directionsUrl} target="_blank" rel="noreferrer">
          <MapPin class="mt-0.5 shrink-0 text-valley-700" size={17} aria-hidden="true" />
          {business.formattedAddress}
        </a>
        <a class="inline-flex items-center gap-2 text-sm font-black text-charcoal-900" href={business.phoneHref}>
          <Phone class="text-valley-700" size={17} aria-hidden="true" />
          {business.phoneDisplay}
        </a>
      </div>

      <div class="mt-5 rounded-2xl border border-smoke-200 bg-white/90 p-4 shadow-sm">
        <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
          <div>
            <h2 class="text-sm font-black uppercase tracking-[0.16em] text-smoke-500">Hours</h2>
            <div class="mt-2 grid gap-1 text-sm font-bold text-charcoal-700">
              {business.hours.map((hour) => <p><span class="text-charcoal-900">{hour.label}:</span> {hour.display}</p>)}
            </div>
          </div>
          <p class="store-status" data-store-open-status>Checking hours...</p>
        </div>
      </div>

      <div class="mt-5">
        <MapEmbed />
      </div>
    </div>
  </div>
</section>

<script>
  const statusElement = document.querySelector<HTMLElement>('[data-store-open-status]');

  const getCentralTimeParts = () => {
    const formatter = new Intl.DateTimeFormat('en-US', {
      timeZone: 'America/Chicago',
      weekday: 'short',
      hour: '2-digit',
      minute: '2-digit',
      hourCycle: 'h23',
    });
    const parts = formatter.formatToParts(new Date());
    const value = (type: string) => parts.find((part) => part.type === type)?.value ?? '';

    return {
      weekday: value('weekday'),
      hour: Number(value('hour')),
      minute: Number(value('minute')),
    };
  };

  const updateStoreStatus = () => {
    if (!statusElement) return;
    const { weekday, hour, minute } = getCentralTimeParts();
    const currentMinutes = hour * 60 + minute;
    const openMinutes = 10 * 60;
    const closeMinutes = weekday === 'Sun' ? 19 * 60 : 22 * 60;
    const isOpen = currentMinutes >= openMinutes && currentMinutes < closeMinutes;

    statusElement.textContent = isOpen ? 'Open now' : 'Closed';
    statusElement.dataset.open = String(isOpen);
  };

  updateStoreStatus();
  window.setInterval(updateStoreStatus, 60 * 1000);
</script>
